{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:allow-message",
    "dialog:allow-ask",
     "dialog:allow-save", 
     "dialog:default",
    "core:window:allow-close",
    "fs:default",
    "fs:allow-copy-file",
    {
      "identifier": "fs:allow-appdata-read-recursive",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-document-write-recursive",
      "allow": [{ "path": "$$APPDATA/**" }]
    }
    
  ]
}
