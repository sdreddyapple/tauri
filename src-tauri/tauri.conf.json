{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "satya-test",
  "version": "0.1.0",
  "identifier": "com.sd.usermanager",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/satya-test/browser"
  },
  "app": {
    "windows": [
      {
        "title": "SDREDDY's User Manager",
        "fullscreen": false,
        "resizable": true,
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "plugins": {
    "sql": {
      "databases": [
        "sqlite:assignments.db"
      ]
    },
    "fs": {},
    "dialog": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}